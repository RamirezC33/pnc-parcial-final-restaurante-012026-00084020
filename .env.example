# Copiar a .env y ajustar. NO subir el .env real al repositorio.

# Contraseña de PostgreSQL
POSTGRES_PASSWORD=restaurante

# Secreto para firmar los JWT (mínimo 32 bytes). Generar uno propio, p. ej.:
#   openssl rand -base64 48
APP_JWT_SECRET=dev-only-insecure-secret-change-me-please-min-32-bytes

# Expiraciones
APP_JWT_ACCESS_MINUTES=15
APP_JWT_REFRESH_DAYS=7

# Credenciales del administrador inicial (seed)
APP_SEED_ADMIN_USERNAME=admin
APP_SEED_ADMIN_PASSWORD=Admin123!
